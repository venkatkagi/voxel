{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Voxel",
  "version": "0.1.0",
  "identifier": "com.voxel.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Voxel",
        "width": 1,
        "height": 1,
        "visible": false,
        "decorations": false,
        "skipTaskbar": true
      },
      {
        "label": "floating-pill",
        "url": "/#/pill",
        "title": "",
        "width": 320,
        "height": 80,
        "visible": false,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "resizable": false,
        "skipTaskbar": true,
        "shadow": false
      },
      {
        "label": "settings",
        "url": "/#/settings",
        "title": "Voxel Settings",
        "width": 900,
        "height": 620,
        "minWidth": 700,
        "minHeight": 500,
        "visible": true,
        "decorations": false,
        "transparent": true,
        "resizable": true,
        "skipTaskbar": false,
        "shadow": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src https://api.groq.com https://api.deepgram.com https://api.assemblyai.com https://api.anthropic.com https://api.openai.com https://generativelanguage.googleapis.com; script-src 'self'; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installMode": "both"
      }
    }
  }
}
